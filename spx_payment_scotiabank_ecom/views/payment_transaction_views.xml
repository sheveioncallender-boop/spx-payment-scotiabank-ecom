<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="payment_transaction_form_scotiabank_ecom" model="ir.ui.view">
        <field name="name">payment.transaction.form.scotiabank.ecom</field>
        <field name="model">payment.transaction</field>
        <field name="inherit_id" ref="payment.payment_transaction_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet//notebook" position="inside">
                <page string="Scotiabank eCom+" name="scotiabank_ecom_tx" invisible="provider_code != 'scotiabank_ecom'">
                    <group string="Transaction Details">
                        <field name="scotia_oid" readonly="1"/>
                        <field name="scotia_ipg_transaction_id" readonly="1"/>
                        <field name="scotia_refnumber" readonly="1"/>
                        <field name="scotia_approval_code" readonly="1"/>
                        <field name="scotia_processor_response_code" readonly="1"/>
                        <field name="scotia_3ds_response" readonly="1"/>
                        <field name="scotia_card_mask" readonly="1"/>
                    </group>
                    <group string="Gateway Amount / Currency">
                        <field name="scotia_gateway_amount" readonly="1"/>
                        <field name="scotia_gateway_currency_numeric" readonly="1"/>
                        <field name="scotia_gateway_currency_alpha" readonly="1"/>
                    </group>
                    <group string="Response Validation">
                        <field name="scotia_response_status" readonly="1"/>
                        <field name="scotia_response_hash_validated" readonly="1"/>
                        <field name="scotia_last_response" readonly="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
