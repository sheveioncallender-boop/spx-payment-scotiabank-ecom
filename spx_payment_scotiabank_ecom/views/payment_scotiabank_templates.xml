<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="redirect_form_scotiabank_ecom" name="Scotiabank eCom+ Redirect Form">
        <form id="o_scotiabank_ecom_redirect_form" t-att-action="api_url" method="post">
            <t t-foreach="inputs" t-as="item">
                <input type="hidden" t-att-name="item[0]" t-att-value="item[1]"/>
            </t>
            <noscript>
                <button type="submit" class="btn btn-primary">Pay with Scotiabank eCom+</button>
            </noscript>
        </form>
        <script type="text/javascript">
            (function () {
                var form = document.getElementById('o_scotiabank_ecom_redirect_form');
                if (form) { form.submit(); }
            })();
        </script>
    </template>

    <template id="scotiabank_handoff_page" name="Scotiabank eCom+ Handoff Page">
        <t t-call="website.layout">
            <div class="spx-scotia-page" t-att-style="'background-color:%s;' % background_color">
                <div class="spx-scotia-card">
                    <div class="spx-scotia-header" t-att-style="'background-color:%s;' % header_color">
                        <img t-att-src="logo_url" alt="Logo" class="spx-scotia-logo"/>
                        <span class="spx-scotia-secure">Secure Payment</span>
                    </div>
                    <div class="spx-scotia-body">
                        <t t-if="display_mode == 'iframe'">
                            <h2>Secure Scotiabank eCom+ Payment</h2>
                            <p class="spx-scotia-muted" t-esc="loading_message"/>
                            <form id="spx_scotia_gateway_form" t-att-action="gateway_url" method="post" target="spx_scotia_frame">
                                <t t-foreach="gateway_fields" t-as="item">
                                    <input type="hidden" t-att-name="item[0]" t-att-value="item[1]"/>
                                </t>
                            </form>
                            <iframe name="spx_scotia_frame" id="spx_scotia_frame" class="spx-scotia-iframe"></iframe>
                            <script type="text/javascript">
                                (function () {
                                    var form = document.getElementById('spx_scotia_gateway_form');
                                    if (form) { form.submit(); }
                                })();
                            </script>
                        </t>
                        <t t-else="">
                            <div class="spx-scotia-icon">💳</div>
                            <h2>You are being redirected to Scotiabank to complete your secure payment.</h2>
                            <p class="spx-scotia-muted" t-esc="handoff_message"/>
                            <div class="spx-scotia-details">
                                <div><strong>Order Reference</strong><span t-esc="reference"/></div>
                                <div><strong>Amount</strong><span t-esc="amount_display"/></div>
                            </div>
                            <p class="spx-scotia-lock">Your payment is secure and encrypted.</p>
                            <form id="spx_scotia_gateway_form" t-att-action="gateway_url" method="post">
                                <t t-foreach="gateway_fields" t-as="item">
                                    <input type="hidden" t-att-name="item[0]" t-att-value="item[1]"/>
                                </t>
                                <button type="submit" class="spx-scotia-button" t-att-style="'background-color:%s;' % button_color">
                                    Proceed to Secure Payment
                                </button>
                            </form>
                            <script type="text/javascript">
                                (function () {
                                    var form = document.getElementById('spx_scotia_gateway_form');
                                    window.setTimeout(function () { if (form) { form.submit(); } }, 1200);
                                })();
                            </script>
                        </t>
                        <t t-if="show_powered_by">
                            <div class="spx-scotia-powered">Payment integration powered by SPXCORP LTD</div>
                        </t>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
