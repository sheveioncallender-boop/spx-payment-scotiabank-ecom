<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="account_payment_method_scotiabank_ecom_in" model="account.payment.method">
        <field name="name">Scotiabank eCom+</field>
        <field name="code">scotiabank_ecom</field>
        <field name="payment_type">inbound</field>
    </record>

    <!-- Run on install/upgrade to make sure the selected payment journal has the required
         accounting payment method line. Without this, Odoo can approve the transaction but
         fail during payment post-processing with: "Please define a payment method line on your payment." -->
    <function model="payment.provider" name="_scotia_setup_all_account_payment_lines"/>
</odoo>
